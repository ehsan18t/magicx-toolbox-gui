{
  "name": "magicx-toolbox",
  "version": "3.0.0",
  "description": "MagicX Toolbox - Windows System Optimization & Tweaking Application",
  "author": "Ehsan Khan <ehsan18t@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ehsan18t/magicx-toolbox-gui"
  },
  "keywords": [
    "tauri",
    "svelte",
    "sveltekit",
    "vite",
    "tailwindcss",
    "starter-template"
  ],
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "build:debug": "tauri build --debug",
    "prepare": "svelte-kit sync || echo ''",
    "copy-icons": "cpy src-tauri/icons/Toolbox.ico static/icons --flat",
    "postinstall": "pnpm run copy-icons",
    "clean": "rimraf .svelte-kit dist src-tauri/target",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "format:rust": "cd src-tauri && cargo fmt",
    "format:rust:check": "cd src-tauri && cargo fmt -- --check",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "lint:rust": "cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings",
    "lint:rust:fix": "cd src-tauri && cargo clippy --all-targets --all-features --fix --allow-dirty --allow-staged",
    "type-check": "tsc --noEmit",
    "validate": "pnpm run format:check && pnpm run type-check && pnpm run check && pnpm run format:rust:check && pnpm run lint:rust && pnpm run lint",
    "tauri": "tauri"
  },
  "dependencies": {
    "@leeoniya/ufuzzy": "^1.0.19",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.2",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@iconify-json/bi": "latest",
    "@iconify-json/fluent": "latest",
    "@iconify-json/icon-park-twotone": "latest",
    "@iconify-json/mdi": "latest",
    "@iconify-json/ri": "latest",
    "@iconify-json/tabler": "latest",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.70.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "cpy-cli": "^7.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.22.0",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "rimraf": "^6.1.3",
    "svelte": "^5.56.7",
    "svelte-check": "^4.7.3",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.1.5"
  }
}
